# Production — copy to .env.prod (gitignored). All data stores are external.
#
#   cp .env.prod.example .env.prod
#   make migrate-prod
#   make prod-up

COMPOSE_PROJECT_NAME=brenox-prod
DEPLOY_RESTART=always

DB_USER=brenox_prod
DB_PASSWORD=change-me-prod-db
DB_HOST=prod-db.example.com
DB_PORT=5432
DB_NAME=brenox
DB_SSLMODE=require

REDIS_URL=rediss://:password@prod-redis.example.com:6379/0

S3_ENDPOINT=s3.amazonaws.com
S3_BUCKET=brenox-prod-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true
S3_REGION=us-east-1

JWT_SECRET=change-me-prod-min-32-random-bytes
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_GRACE_HOURS=168

CORS_ALLOWED_ORIGINS=https://www.breno-x.com
WS_ALLOWED_ORIGINS=https://www.breno-x.com

PORT=8080
MAX_UPLOAD_BYTES=10485760
PRESENCE_TTL_SECONDS=120
CALL_MAX_PARTICIPANTS=25
API_RATE_LIMIT_PER_MINUTE=120
HTTP_RATE_LIMIT_PER_IP=300
MAX_REQUEST_BODY_BYTES=1048576
