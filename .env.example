# Database (matches docker-compose.dev.yaml)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=brenox

# JWT signing secret — change in production
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_GRACE_HOURS=168

# Browser SDK CORS — comma-separated origins; falls back to WS_ALLOWED_ORIGINS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# WebSocket — comma-separated origins; empty or * allows all (dev only)
WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WS_MAX_CONNECTIONS_PER_USER=5
WS_MAX_CONNECTIONS_PER_IP=20

# Redis — required for multi-instance realtime; omit for local-only single node
REDIS_URL=redis://localhost:6379/0

# Presence key TTL — refreshed on WS connect and heartbeat ping
PRESENCE_TTL_SECONDS=120

# MinIO / S3-compatible object storage
S3_ENDPOINT=localhost:9000
S3_BUCKET=brenox
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1
MAX_UPLOAD_BYTES=10485760

# Voice/video calls — max participants per call (default 25)
CALL_MAX_PARTICIPANTS=25

# Public Developer API — requests per minute per API key (default 120)
API_RATE_LIMIT_PER_MINUTE=120

# Global HTTP rate limit per client IP (default 300/min)
HTTP_RATE_LIMIT_PER_IP=300

# Max request body size in bytes (default 1MB)
MAX_REQUEST_BODY_BYTES=1048576
