# Production-like Docker stack — copy to .env and set strong values
# Same DB_* vars as .env.example; Compose overrides DB_HOST for the API container

DB_USER=postgres
DB_PASSWORD=change-me-use-openssl-rand
DB_HOST=localhost
DB_PORT=5432
DB_NAME=brenox

MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password

JWT_SECRET=change-me-min-32-random-bytes

REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=localhost:9000
S3_BUCKET=brenox
S3_ACCESS_KEY=change-me-minio-user
S3_SECRET_KEY=change-me-minio-password
S3_USE_SSL=false
S3_REGION=us-east-1

CORS_ALLOWED_ORIGINS=https://app.example.com
WS_ALLOWED_ORIGINS=https://app.example.com

PORT=8080
