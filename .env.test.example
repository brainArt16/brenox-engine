# Test — copy to .env.test (gitignored). Postgres, Redis, and S3 are managed externally.
#
#   cp .env.test.example .env.test
#   make migrate-test
#   make test-up

COMPOSE_PROJECT_NAME=brenox-test
DEPLOY_RESTART=unless-stopped

DB_USER=brenox_test
DB_PASSWORD=change-me-test-db
DB_HOST=test-db.example.com
DB_PORT=5432
DB_NAME=brenox_test
DB_SSLMODE=require

REDIS_URL=rediss://:password@test-redis.example.com:6379/0

S3_ENDPOINT=s3.amazonaws.com
S3_BUCKET=brenox-test-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true
S3_REGION=us-east-1

JWT_SECRET=change-me-test-min-32-bytes
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_GRACE_HOURS=168

CORS_ALLOWED_ORIGINS=https://test.example.com
WS_ALLOWED_ORIGINS=https://test.example.com

PORT=8080
MAX_UPLOAD_BYTES=10485760
PRESENCE_TTL_SECONDS=120
CALL_MAX_PARTICIPANTS=25
API_RATE_LIMIT_PER_MINUTE=120
SANDBOX_API_RATE_LIMIT_PER_MINUTE=30
SANDBOX_MAX_USERS=100
SANDBOX_MAX_CHANNELS=20
SANDBOX_MAX_MESSAGES=1000
SANDBOX_API_KEY_TTL_DAYS=90
SANDBOX_DATA_TTL_DAYS=30
SANDBOX_CLEANUP_INTERVAL_HOURS=24
HTTP_RATE_LIMIT_PER_IP=300
MAX_REQUEST_BODY_BYTES=1048576
