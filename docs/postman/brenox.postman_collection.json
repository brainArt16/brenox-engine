{
  "info": {
    "_postman_id": "brenox-api-collection",
    "name": "Brenox API",
    "description": "Brenox realtime communication platform — HTTP API.\n\nImport `brenox.postman_environment.json`. Run **Auth → Login** first.\n\nWebSocket: `GET {{baseUrl}}/api/ws?workspace_id={{workspaceId}}&channel_id={{channelId}}&token={{token}}` or use Bearer header. See docs/WEBSOCKET_EVENTS.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "workspaceId", "value": "1" },
    { "key": "channelId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Returns database and Redis status. No auth required."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"demo_user\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('workspaceId', json.id);",
                  "  pm.environment.set('workspaceId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"slug\": \"acme-demo\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces"
          }
        },
        {
          "name": "List Workspaces",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces"
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "List Members",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members"
          }
        },
        {
          "name": "Add Member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@example.com\",\n  \"role\": \"member\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members"
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"moderator\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/2"
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/2"
          }
        }
      ]
    },
    {
      "name": "Channels",
      "item": [
        {
          "name": "Create Channel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ID) {",
                  "  pm.collectionVariables.set('channelId', json.ID);",
                  "  pm.environment.set('channelId', json.ID);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"general\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels"
          }
        },
        {
          "name": "List Channels",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels"
          }
        },
        {
          "name": "Join Channel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/join"
          }
        },
        {
          "name": "Leave Channel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/leave"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"hello from Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages"
          }
        },
        {
          "name": "List Messages",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces", "{{workspaceId}}", "channels", "{{channelId}}", "messages"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Presence",
      "item": [
        {
          "name": "Get Online Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/presence",
            "description": "Returns online_users with user_id, status, connection_count, last_seen."
          }
        },
        {
          "name": "Get Workspace Online Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/presence"
          }
        },
        {
          "name": "Update My Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"away\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me/status",
            "description": "Status: online, away, or offline. Broadcasts presence.status to active channels."
          }
        }
      ]
    },
    {
      "name": "WebSocket",
      "item": [
        {
          "name": "Connect (documentation)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/ws?workspace_id={{workspaceId}}&channel_id={{channelId}}&token={{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ws"],
              "query": [
                { "key": "workspace_id", "value": "{{workspaceId}}" },
                { "key": "channel_id", "value": "{{channelId}}" },
                { "key": "token", "value": "{{token}}" }
              ]
            },
            "description": "Requires workspace + channel membership. Auth via Bearer header or ?token=. Returns 429 if connection limits exceeded. See docs/WEBSOCKET_EVENTS.md."
          }
        }
      ]
    }
  ]
}
