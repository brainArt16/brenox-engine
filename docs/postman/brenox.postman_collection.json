{
  "info": {
    "_postman_id": "brenox-api-collection",
    "name": "Brenox API",
    "description": "Brenox realtime communication platform — HTTP API.\n\nImport `brenox.postman_environment.json`. Run **Auth → Login** first.\n\nWebSocket: `GET {{baseUrl}}/api/ws?workspace_id={{workspaceId}}&channel_id={{channelId}}&token={{token}}` or use Bearer header. See docs/WEBSOCKET_EVENTS.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "workspaceId", "value": "1" },
    { "key": "channelId", "value": "1" },
    { "key": "messageId", "value": "1" },
    { "key": "callId", "value": "1" },
    { "key": "appId", "value": "1" },
    { "key": "apiKey", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Version",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/version",
            "description": "Engine release semver and Developer API contract version. No auth required."
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Returns database and Redis status. No auth required."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"demo_user\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Accepts valid or recently expired JWT. See JWT_REFRESH_GRACE_HOURS."
          }
        }
      ]
    },
    {
      "name": "User Profile",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update Me",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"demo_user\"\n}" },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"secret\",\n  \"new_password\": \"newsecret123\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me/password"
          }
        },
        {
          "name": "Get My Status",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me/status"
          }
        }
      ]
    },
    {
      "name": "Workspaces",
      "item": [
        {
          "name": "Create Workspace",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('workspaceId', json.id);",
                  "  pm.environment.set('workspaceId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"slug\": \"acme-demo\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces"
          }
        },
        {
          "name": "List Workspaces",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces"
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}"
          }
        },
        {
          "name": "List Members",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members"
          }
        },
        {
          "name": "Add Member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@example.com\",\n  \"role\": \"member\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members"
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"moderator\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/2"
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/2"
          }
        }
      ]
    },
    {
      "name": "Channels",
      "item": [
        {
          "name": "Create Channel",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ID) {",
                  "  pm.collectionVariables.set('channelId', json.ID);",
                  "  pm.environment.set('channelId', json.ID);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"general\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels"
          }
        },
        {
          "name": "List Channels",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels"
          }
        },
        {
          "name": "Join Channel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/join"
          }
        },
        {
          "name": "Leave Channel",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/leave"
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"hello from Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages"
          }
        },
        {
          "name": "List Messages",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces", "{{workspaceId}}", "channels", "{{channelId}}", "messages"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "List Message Attachments",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/attachments"
          }
        },
        {
          "name": "Attach Files To Message",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attachments\": [\n    {\n      \"object_key\": \"uploads/1/example/doc.pdf\",\n      \"file_name\": \"doc.pdf\",\n      \"mime_type\": \"application/pdf\",\n      \"size_bytes\": 1024\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/messages/{{messageId}}/attachments"
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "Create Upload URL",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_name\": \"doc.pdf\",\n  \"mime_type\": \"application/pdf\",\n  \"size_bytes\": 1024\n}"
            },
            "url": "{{baseUrl}}/api/uploads",
            "description": "Returns presigned PUT URL and object_key. Upload file to upload_url, then attach via message create or attachments endpoint."
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/notifications?limit=50&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "url": "{{baseUrl}}/api/notifications/1/read"
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/notifications/read-all"
          }
        }
      ]
    },
    {
      "name": "Calls",
      "item": [
        {
          "name": "Initiate Call",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('callId', json.id);",
                  "  pm.environment.set('callId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"voice\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/calls",
            "description": "Creates a ringing call in the channel. mode: voice (default) or video. One active call per channel. Notifies other channel members (call_invite)."
          }
        },
        {
          "name": "Initiate Video Call",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('callId', json.id);",
                  "  pm.environment.set('callId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"video\"\n}"
            },
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/channels/{{channelId}}/calls",
            "description": "Initiate a video call. Signaling: call.offer/answer/ice plus call.video.on/off, call.screen.*, call.recording.*"
          }
        },
        {
          "name": "Join Call",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/calls/{{callId}}/join",
            "description": "Join an existing call. Channel members only. Broadcasts call.join."
          }
        },
        {
          "name": "Leave Call",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/calls/{{callId}}/leave",
            "description": "Leave call. Broadcasts call.leave; call.end when last participant leaves."
          }
        }
      ]
    },
    {
      "name": "Presence",
      "item": [
        {
          "name": "Get Online Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/presence",
            "description": "Returns online_users with user_id, status, connection_count, last_seen."
          }
        },
        {
          "name": "Get Workspace Online Users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/workspaces/{{workspaceId}}/presence"
          }
        },
        {
          "name": "Update My Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"away\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me/status",
            "description": "Status: online, away, or offline. Broadcasts presence.status to active channels."
          }
        }
      ]
    },
    {
      "name": "Developer Apps",
      "item": [
        {
          "name": "Create App",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('appId', json.id);",
                  "  pm.environment.set('appId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My Integration\",\n  \"slug\": \"my-integration\"\n}" },
            "url": "{{baseUrl}}/api/apps",
            "description": "Creates app + dedicated workspace tenant boundary."
          }
        },
        {
          "name": "List Apps",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/apps"
          }
        },
        {
          "name": "Get App",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/apps/{{appId}}"
          }
        },
        {
          "name": "Create API Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.secret) {",
                  "  pm.collectionVariables.set('apiKey', json.secret);",
                  "  pm.environment.set('apiKey', json.secret);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"production\",\n  \"sandbox\": false\n}" },
            "url": "{{baseUrl}}/api/apps/{{appId}}/keys",
            "description": "Secret shown once. Use bx_live_... or bx_test_... for /v1 routes."
          }
        },
        {
          "name": "List API Keys",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/apps/{{appId}}/keys"
          }
        },
        {
          "name": "Revoke API Key",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/apps/{{appId}}/keys/{{keyId}}"
          }
        },
        {
          "name": "Create Webhook",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/webhooks/brenox\",\n  \"events\": [\"message.created\", \"user.provisioned\", \"channel.created\"]\n}"
            },
            "url": "{{baseUrl}}/api/apps/{{appId}}/webhooks"
          }
        },
        {
          "name": "List Webhooks",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/apps/{{appId}}/webhooks"
          }
        },
        {
          "name": "Delete Webhook",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/apps/{{appId}}/webhooks/{{webhookId}}"
          }
        }
      ]
    },
    {
      "name": "Public API v1",
      "item": [
        {
          "name": "Provision User",
          "request": {
            "auth": { "type": "apikey", "apikey": [{ "key": "key", "value": "{{apiKey}}", "type": "string" }] },
            "method": "POST",
            "header": [
